# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=SatSplitBot
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL=https://your-app.vercel.app/tonconnect-manifest.json

# ─── AI Models ────────────────────────────────────────────────────────────────
# Primary: Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Free fallback: Gemini Flash
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyCbbmq6R_8M4Pu6leiNux4XrNDU3isdihU

# Multi-model fallback: OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Local fallback: Ollama (no key needed, just run locally)
OLLAMA_BASE_URL=http://localhost:11434

# ─── ENS / NameStone ──────────────────────────────────────────────────────────
NAMESTONE_API_KEY=your-namestone-api-key
# The parent ENS name you own for subname creation
ENS_PARENT_NAME=satsplit.eth

# ─── XRPL ─────────────────────────────────────────────────────────────────────
# testnet or mainnet
XRPL_NETWORK=testnet
# Organizer wallet (server-side only — used to cash checks)
XRPL_ORGANIZER_SECRET=sEd...

# ─── Xumm (for XRPL signing) ──────────────────────────────────────────────────
XUMM_API_KEY=your-xumm-api-key
XUMM_API_SECRET=your-xumm-api-secret

# ─── BSA x402 / TON Payments ──────────────────────────────────────────────────
# Wallet address that receives x402 payments (your server wallet)
PAYMENT_ADDRESS=UQ...your-ton-wallet-address

# TON network: testnet or mainnet
TON_NETWORK=testnet

# BSA USD stablecoin contract (pre-filled for testnet — do not change)
JETTON_MASTER_ADDRESS=kQCd6G7c_HUBkgwtmGzpdqvHIQoNkYOEE0kSWoc5v57hPPnV

# Facilitator URL — use BSA's hosted facilitator or run locally
# Local: http://localhost:3000/api/facilitator
# BSA hosted: https://facilitator.bsa.epfl.ch (check BSA docs for current URL)
FACILITATOR_URL=http://localhost:3000/api/facilitator

# Toncenter RPC (free key at toncenter.com)
TON_RPC_URL=https://testnet.toncenter.com/api/v2/jsonRPC
RPC_API_KEY=your-toncenter-api-key

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENS_ENABLED=true
XRPL_ENABLED=true
X402_ENABLED=false
